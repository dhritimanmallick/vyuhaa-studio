{
  "name": "vyuhaa-video-studio",
  "version": "1.0.0",
  "description": "Vyuhaa Video Studio - Professional video editor for medical researchers and medtech teams",
  "author": "Vyuhaa Med Data Private Limited <contact@vyuhaadata.com>",
  "homepage": "https://www.vyuhaadata.com",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "build:electron": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.vyuhaadata.videostudio",
    "productName": "Vyuhaa Video Studio",
    "copyright": "Copyright © 2026 Vyuhaa Med Data Private Limited",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "build/icon.*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Vyuhaa Med Data Private Limited"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vyuhaa Video Studio",
      "welcomeTitle": "Welcome to Vyuhaa Video Studio",
      "runAfterFinish": true
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Video"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  }
}
